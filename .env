# Database connection string (PostgreSQL)
# For local PostgreSQL: postgresql://username:password@localhost:5432/verilist?schema=public
# For Supabase/Neon: postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
DATABASE_URL="file:./dev.db"

PORT=5000
JWT_SECRET="super-secret-key-change-this-in-production-12345"
NODE_ENV="development"

# Google OAuth 2.0 — Paste your Client ID from Google Cloud Console
# Instructions: See google_oauth_setup.md artifact
GOOGLE_CLIENT_ID="434839579120-nnbdu1iscf5ltrcq94qrc6geaas862v8.apps.googleusercontent.com"

# Firebase Config
FIREBASE_CREDENTIALS_PATH="backend/service-account.json"
